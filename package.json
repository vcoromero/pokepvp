{
  "name": "pokepvp",
  "version": "0.1.0",
  "description": "PokePVP backend - minimal Express + PokeAPI proxy",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules node --no-warnings node_modules/jest/bin/jest.js",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules node --no-warnings node_modules/jest/bin/jest.js --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules node --no-warnings node_modules/jest/bin/jest.js --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pokemon",
    "pvp",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.0",
    "supertest": "^7.2.2"
  }
}
